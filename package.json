    "@mastra/memory": "^0.10.4",
    "@mastra/qdrant": "^0.10.2",
    "@mastra/rag": "^0.10.2",
    "@supabase/supabase-js": "^2.53.0",
    "ai": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mammoth": "^1.9.1",
    "multer": "^2.0.0",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.6.7",
    "p-limit": "^6.1.0",
    "pdf-parse": "^1.1.1",
    "pdf.js-extract": "^0.2.1",
    "replicate": "^1.0.1",
    "tiktoken": "^1.0.17",
    "word-extractor": "^1.0.4",
    "zod": "^3.25.67"
