{
  "name": "PersonaVault",
  "version": "1.0.0",
  "description": "Personal document vault with RAG search and chat",
  "packageManager": "pnpm@9.15.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npx mastra dev",
    "build": "mastra build",
    "start": "mastra start",
    "api": "npx tsx src/api/server.ts",
    "api:dev": "npx tsx --watch src/api/server.ts",
    "ingest": "npx tsx src/scripts/ingest-documents.ts",
    "ingest-fixed": "npx tsx src/scripts/ingest-documents-fixed.ts",
    "ingest-cloud": "npx tsx src/scripts/ingest-documents-cloud.ts",
    "setup-qdrant": "npx tsx src/scripts/setup-qdrant.ts",
    "setup-cloud-qdrant": "npx tsx src/scripts/setup-cloud-qdrant.ts",
    "clear-documents": "npx tsx src/scripts/clear-documents.ts",
    "test-extraction": "tsx src/utils/test-document-extraction.ts",
    "debug-qdrant": "npx tsx src/scripts/debug-qdrant-data.ts",
    "test-api": "npx tsx src/scripts/test-api.ts",
    "test-db": "npx tsx src/scripts/test-database.ts"
  },
  "keywords": [],
